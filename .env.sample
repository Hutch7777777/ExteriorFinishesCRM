# Database Configuration
# Required: PostgreSQL connection string from Neon or your database provider
DATABASE_URL=postgresql://username:password@host:port/database_name

# Authentication (Required)
# Set in Replit Secrets: A secure random string for JWT token signing
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-here

# Optional: Admin User Configuration (for seeding script)
# These credentials will be used when running `tsx scripts/seed.ts`
ADMIN_EMAIL=admin@exteriorfinishes.com
ADMIN_PASSWORD=admin123

# Note: JWT_SECRET should be set in Replit Secrets, not in this file
# The other variables can be set in environment or Replit Secrets